generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppEvent {
  id        BigInt   @id @default(autoincrement())
  kind      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("app_events")
  @@index([kind, createdAt(sort: Desc)])
}

