# Copy to .env and adjust for local dev
POSTGRES_USER=neo
POSTGRES_PASSWORD=neo_dev_change_me
POSTGRES_DB=neo

API_PORT=3000
API_REPLICAS=1

# PgBouncer talks to Postgres; apps talk to PgBouncer
DATABASE_URL=postgresql://neo:neo_dev_change_me@pgbouncer:6432/neo?sslmode=disable
REDIS_URL=redis://redis:6379

# Security hardening
# In production set a strong random token and send it as Authorization: Bearer <token>
ADMIN_TOKEN=change_me_to_long_random_secret

# Restrict browser origins allowed to call API (example: https://app.example.com)
CORS_ORIGIN=

# If true, trust x-forwarded-for for client IP (only behind trusted proxy)
TRUST_PROXY=false
